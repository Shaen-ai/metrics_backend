APP_NAME=Tunzone
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mebel
DB_USERNAME=root
DB_PASSWORD=

SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:3001
SESSION_DOMAIN=localhost

FRONTEND_ADMIN_URL=http://localhost:3000
FRONTEND_PUBLIC_URL=http://localhost:3001
# Marketing /pricing (Stripe cancel redirect). Local landing is often port 3002.
FRONTEND_LANDING_URL=http://localhost:3002

# Stripe Billing — secret from Dashboard; never expose to frontends. Rotate if leaked.
# Alias: STRIPE_SECRET_KEY is also read if STRIPE_SECRET is empty.
STRIPE_SECRET=
# From Stripe CLI (`stripe listen`) or Dashboard webhook endpoint.
# Alias: STRIPE_WEBHOOK_SIGNING_SECRET. Recommended events: checkout.session.completed,
# customer.subscription.updated, customer.subscription.deleted, invoice.paid, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=
# Price IDs (subscription) — Starter / Business / Business Pro × monthly & yearly.
STRIPE_PRICE_STARTER_MONTHLY=price_1TObExHAarLw0BZOxN8YvPI1
STRIPE_PRICE_STARTER_YEARLY=price_1TObExHAarLw0BZOlyYGXylO
STRIPE_PRICE_BUSINESS_MONTHLY=price_1TObl0HAarLw0BZOIZSVT9Rh
STRIPE_PRICE_BUSINESS_YEARLY=price_1TObl0HAarLw0BZOjZfCGL4Z
STRIPE_PRICE_BUSINESS_PRO_MONTHLY=price_1TRB4tHAarLw0BZO1Jt0HeFL
STRIPE_PRICE_BUSINESS_PRO_YEARLY=price_1TRB5bHAarLw0BZO6Uvntz98
# Days of Stripe subscription trial on Checkout (0 to disable). Card on file; first charge after trial.
STRIPE_SUBSCRIPTION_TRIAL_DAYS=14

# Public planner catalog merges active items from this admin’s slug (when use_custom_planner_catalog is false on the target admin).
CATALOG_LIBRARY_SLUG=demo

# Shared secret for Next.js published app → POST /api/internal/usage/consume (must match metrics_platform_published .env)
INTERNAL_API_KEY=

# Optional production overrides for uploaded GLB/GLTF model files and images.
# Local default when MODEL_UPLOAD_PATH is empty: Laravel public disk at storage/app/public/files/{userId}/models.
# Production example: MODEL_UPLOAD_PATH=/var/www/tunzone/files/models and Nginx aliases /files/models/ to that directory.
MODEL_UPLOAD_PATH=
MODEL_UPLOAD_URL_PATH=/files/models
# Local default when IMAGE_UPLOAD_PATH is empty: Laravel public disk at storage/app/public/files/{userId}/{images,materials}.
# Production example: IMAGE_UPLOAD_PATH=/var/www/tunzone/files/images and Nginx aliases /files/images/ to that directory.
IMAGE_UPLOAD_PATH=
IMAGE_UPLOAD_URL_PATH=/files/images

# AI Room Planner intent parsing. AI is only used to return structured intent JSON.
OPENAI_API_KEY=
AI_API_URL=https://api.openai.com/v1/chat/completions
PLANNER_INTENT_MODEL=gpt-4o-mini

# Zoho SMTP (STARTTLS on 587).
# MAIL_USERNAME = mailbox used to authenticate (often support@yourdomain.com).
# MAIL_FROM_* = envelope “From” for automated mail (noreply recommended; configure as allowed alias in Zoho if needed).
# Human replies go via support@ mailto links in the frontends — not MAIL_FROM_*.
MAIL_MAILER=smtp
MAIL_HOST=smtp.zoho.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@tunzone.com"
# Shown in From: and all admin email subjects/body when MAIL_FROM_NAME is empty. Not APP_NAME.
MAIL_BRAND_NAME="Tunzone"
# Overrides MAIL_BRAND_NAME for the From: header when set (quote if it contains spaces).
MAIL_FROM_NAME="Tunzone"

# Optional: full URL to a logo image for HTML admin emails. Default: {FRONTEND_LANDING_URL}/logo.png
# MAIL_BRAND_LOGO_URL=https://yourdomain.com/logo.png

# Reply-To helps deliverability (human inbox) and matches support expectations; use a monitored address.
# MAIL_REPLY_TO_ADDRESS=support@tunzone.com
# MAIL_REPLY_TO_NAME=Tunzone

# Landing “About” contact form delivers here (server-side). Defaults to support@tunzone.com.
# CONTACT_INBOUND_EMAIL=support@tunzone.com

# SMTP EHLO hostname should match your sending domain (helps spam scoring). Default: host from API_PUBLIC_URL / APP_URL.
# MAIL_EHLO_DOMAIN=tunzone.com

# --- Production (set on server; Tunzone examples) ---
# Public URL of this API (verification emails, Sanctum, etc.). Must be https:// and must not be localhost.
# Email verification links are {API_PUBLIC_URL}/api/auth/verify-email.
# APP_URL=https://api.tunzone.com
# If APP_URL is ever wrong for outside mail/links only, override:
# API_PUBLIC_URL=https://api.tunzone.com
# FRONTEND_PUBLIC_URL=https://published.tunzone.com
# FRONTEND_ADMIN_URL=https://admin.example.com
# For Zoho (and most providers): add SPF, DKIM, and DMARC for tunzone.com so noreply@ matches DNS.
